---
import { ClientRouter } from "astro:transitions";
import LoadingIndicator from "astro-loading-indicator/component";
import "../styles/mvp.css";
import Nav from "../components/Nav.astro";
import NotificationBar from "../components/NotificationBar.astro";
import { SEO } from "astro-seo";

interface Props {
	ogImage?: string;
	ogImageWidth?: number;
	ogImageHeight?: number;
	ogTitle?: string;
	ogDescription?: string;
	hideNotificationBar?: boolean;
}

const {
	ogImage = "https://ik.imagekit.io/ty6gikkxo/logo.png?updatedAt=1737934952181",
	ogImageWidth = 1200,
	ogImageHeight = 630,
	ogTitle = "Children's Book For All",
	ogDescription = "An evocative space for play, wonder, joy and community",
	hideNotificationBar = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link
			rel="icon"
			type="image/svg+xml"
			href="https://ik.imagekit.io/ty6gikkxo/favicon.svg?updatedAt=1737934952187"
		/>
		<SEO
			title={ogTitle}
			description={ogDescription}
			openGraph={{
				basic: {
					title: ogTitle,
					type: "website",
					image: ogImage,
				},
				image: {
					width: ogImageWidth,
					height: ogImageHeight,
					alt: ogTitle,
				},
			}}
			extend={{
				// extending the default link tags
				link: [{ rel: "icon", href: "/favicon.svg" }],
				// extending the default meta tags
				meta: [
					{
						name: "twitter:image",
						content: ogImage,
					},
					{
						name: "twitter:title",
						content: ogTitle,
					},
					{ name: "twitter:description", content: ogDescription },
				],
			}}
		/>
		<title>Children's Book For All</title>
		<ClientRouter />
		<LoadingIndicator color="#7e22ce" />
		<script is:inline>
			if (localStorage.getItem("notification-dismissed") === "true") {
				document.documentElement.style.setProperty("--notification-bar-display", "none");
			}
		</script>
	</head>
	<body>
		{!hideNotificationBar && <NotificationBar />}
		<Nav />
		<slot />
	</body>
	<script
			data-goatcounter="https://childrensbookforall.goatcounter.com/count"
			async
			src="//gc.zgo.at/count.js">
	</script>
	<style>
		body {
			font-family:
				"Inter",
				system-ui,
				-apple-system,
				BlinkMacSystemFont,
				"Segoe UI",
				Roboto,
				Oxygen,
				Ubuntu,
				Cantarell,
				"Open Sans",
				"Helvetica Neue",
				sans-serif;
			background-image: linear-gradient(
					rgba(255, 255, 255, 0.4),
					rgba(255, 255, 255, 0.4)
				),
				url("https://ik.imagekit.io/ty6gikkxo/bg3.png?updatedAt=1737936538419");
			background-size: cover;
		}
	</style>
</html>
