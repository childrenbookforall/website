---
import { ClientRouter } from "astro:transitions";
import LoadingIndicator from "astro-loading-indicator/component";
import "../styles/mvp.css";
import Nav from "../components/Nav.astro";
import Gift from "../components/Gift.astro";
import { SEO } from "astro-seo";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link
			rel="icon"
			type="image/svg+xml"
			href="https://ik.imagekit.io/ty6gikkxo/favicon.svg?updatedAt=1737934952187"
		/>
		<SEO
			title="Children's Book For All"
			description="An evocative space for play, wonder, joy and community"
			openGraph={{
				basic: {
					title: "Children's Book For All",
					type: "Website",
					image: "https://ik.imagekit.io/childrensbookforall/logo.png",
				},
			}}
			extend={{
				// extending the default link tags
				link: [{ rel: "icon", href: "/favicon.svg" }],
				// extending the default meta tags
				meta: [
					{
						name: "twitter:image",
						content:
							"https://ik.imagekit.io/childrensbookforall/logo.png",
					},
					{
						name: "twitter:title",
						content: "Children's Book For All",
					},
					{ name: "twitter:description", content: "An evocative space for play, wonder, joy and community" },
				],
			}}
		/>
		<title>Children's Book For All</title>
		<ClientRouter />
		<LoadingIndicator color="#7e22ce" />
	</head>
	<body>
		<Nav />
		<slot />
	</body>
	<script
			data-goatcounter="https://childrensbookforall.goatcounter.com/count"
			async
			src="//gc.zgo.at/count.js">
	</script>
	<style>
		body {
			font-family:
				"Inter",
				system-ui,
				-apple-system,
				BlinkMacSystemFont,
				"Segoe UI",
				Roboto,
				Oxygen,
				Ubuntu,
				Cantarell,
				"Open Sans",
				"Helvetica Neue",
				sans-serif;
			background-image: linear-gradient(
					rgba(255, 255, 255, 0.4),
					rgba(255, 255, 255, 0.4)
				),
				url("https://ik.imagekit.io/ty6gikkxo/bg3.png?updatedAt=1737936538419");
			background-size: cover;
		}
	</style>
</html>
