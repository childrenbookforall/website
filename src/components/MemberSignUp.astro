---
import { actions, isInputError, isActionError } from "astro:actions";
import '../styles/international-telephone-input.css';

const result = Astro.getActionResult(actions.member.addMember);
const inputErrors = isInputError(result?.error)? result?.error.fields:{};
const actionError = result?.error?.status === 500;

console.log(result);
// const actionError = isActionError(result?.error);
---

<form method="POST" action={actions.member.addMember}>
    <h1>Stay updated about our upcoming readings</h1>
    <label for="name">Name</label>
    <input transition:persist required type="text" name="name" id="name" />
    {inputErrors.name && <span style="margin-top: -1rem" class="error">Please check your name again</span>}
    <label for="email">Email</label>
    <input transition:persist required type="email" name="email" id="email" />
    {inputErrors.email && <span style="margin-top: -1rem" class="error">Please check your email again</span>}
    <!-- {actionError && <span style="margin-top: -1rem" class="error">Your email id is already registered for CBA updates</span>} -->
    <label for="phone">Phone</label>
    <div transition:persist class="iti">
        <input transition:persist required type="tel" name="phone" id="phone" />
    </div>
    {inputErrors.phone && <span class="error">Please check your phone number again</span>}
    <input type="submit" id="submit" value="Sign me up!" />
</form>
<script src="../scripts/international-telephone-input.js"></script>
<script>
    const form = document.querySelector('form');
    const submitBtn = document.querySelector('#submit');
    form?.addEventListener('submit', ()=>{
        submitBtn?.setAttribute("disabled", "");
    })
</script>
<style>
    form {
        display: flex;
        flex-direction: column;
        max-width: 85%;
        margin: auto;
        padding: 0rem 1.5rem 1.5rem 2rem;
        gap: 0.5rem;
        width: 350px;
    }
    form h1{
        font-size: 1.7rem;
    }
    .error{
        color: red;
        display: block;
        text-align: left;
    }
    .iti{
        position: relative;
        display: inline-block;
    }

    #phone{
        margin-top: 0;
        margin-bottom: 0;
        padding-left: 52px;
        padding-right: 6px;
    }
    label{
        font-weight: 500;
    }
</style>
