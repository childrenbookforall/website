---
import { Icon } from "astro-icon/components";
const pathname = new URL(Astro.request.url).pathname;
const currentpath = pathname.split("/")[1];
---
<button id="menu">
    <div class="container">
        <a id="menu-toggle" class="menu-toggle">
            <span class="menu-toggle-bar menu-toggle-bar--top"></span>
            <span class="menu-toggle-bar menu-toggle-bar--middle"></span>
            <span class="menu-toggle-bar menu-toggle-bar--bottom"></span>
        </a>
    </div>
</button>

<div id="navigation">
    <ul>
        <!-- <li>
            <a
                class={currentpath == "sign-up" ? "active" : ""}
                id="home"
                href="/"
            >
            <img src="/home.png" width="32" alt="Home Icon">
                Home
            </a>
        </li> -->
        <li>
            <a
                class={currentpath == "our-stories" ? "active" : ""}
                id="our-stories"
                href="/our-stories"
            >
                <img src="/stories.png" width="28" alt="Stories Icon" />
                Our Stories
            </a>
        </li>
        <li>
            <a
                class={currentpath == "past-readings" ? "active" : ""}
                id="past-readings"
                href="/past-readings"
            >
                <img src="/readings.png" width="24" alt="Readings Icon" />
                Past Readings
            </a>
        </li>
        <li>
            <a
                class={currentpath == "activities" ? "active" : ""}
                id="activities"
                href="/activities"
            >
                <img src="/activity.png" width="28" alt="Activity Icon" />
                Activities
            </a>
        </li>
        <li>
            <a
                class={currentpath == "support-group" ? "active" : ""}
                id="support-group"
                href="/support-group"
            >
                <img src="/support.png" width="28" alt="Support Icon" />
                Support Groups
            </a>
        </li>
        <!-- <li>
            <a
                class={currentpath == "gift" ? "active" : ""}
                id="gift"
                href="/gift"
            >
                <img src="/gift.png" width="28" alt="Gift Icon" />
                Gift a Children's Book
            </a>
        </li> -->
    </ul>
</div>

<script>
    document.addEventListener("astro:page-load", () => {
        const navigation = document.querySelector<HTMLElement>("#navigation");

        const menuToggle = document.querySelector('#menu-toggle');
        menuToggle?.addEventListener("click",()=>{
            document.body.classList.toggle('nav-open');
            navigation?.classList.toggle("show");
        })
    });

    // Burger to cross menu
   
</script>

<style>
    #menu {
        background: none;
        color: black;
        padding: 0;
        border: none;
        margin: 0;
    }

    #navigation {
        width: 100%;
        left: 0;
        top: 0;
        display: none;
        background-color: white;
        border-radius: 1rem;
        border: 1px solid grey;
    }
    .show {
        display: block !important;
    }
    .active {
        /* background-color: #344CB7; */
        /* padding: 0.5rem 1rem; */
        /* border-radius: 2rem; */
        text-decoration: underline !important;
        text-decoration-color: oklch(89% 0.146 91.5) !important;
        /* color: #293c92 !important; */
        font-weight: 500 !important;
        text-underline-offset: 0.5rem !important;
        text-decoration-thickness: 4px !important;
        /* color: white !important; */
    }
    li {
        padding: 0 0.5rem;
    }
    li a {
        color: #3b3b3b;
        font-size: 1.1rem;
        text-decoration: none;
        font-weight: 500;
        display: flex;
        /* justify-content: center; */
        align-items: center;
        gap: 0.5rem;
        text-underline-offset: 0.5rem !important;
    }
    li a:hover {
        text-decoration: underline !important;
    }
    @media screen and (min-width: 768px) {
        #navigation {
            display: block;
            background-color: transparent;
            border: none;
        }
        button {
            visibility: hidden;
        }
    }

    /* CSS for hamburger menu */
    .container {
        position: relative;
        padding: 1rem;
    }

    .menu-toggle {
        position: absolute;
        right: 0rem;
        top: 49%;
        transform: translate(0, -50%);
        height: 26px;
        width: 29px;

        &,
        &:hover {
            color: #000;
        }
    }

    .menu-toggle-bar {
        display: block;
        position: absolute;
        top: 50%;
        margin-top: -1px;
        right: 0;
        width: 100%;
        height: 4px;
        border-radius: 4px;
        background-color: black;
        transition: all 0.3s ease;

        &.menu-toggle-bar--top {
            transform: translate(0, -8px);
        }
        &.menu-toggle-bar--middle {
        }
        &.menu-toggle-bar--bottom {
            transform: translate(0, 8px);
        }

        .nav-open & {
            &.menu-toggle-bar--top {
                transform: translate(0, 0) rotate(45deg);
            }
            &.menu-toggle-bar--middle {
                opacity: 0;
            }
            &.menu-toggle-bar--bottom {
                transform: translate(0, 0) rotate(-45deg);
            }
        }
    }
</style>
