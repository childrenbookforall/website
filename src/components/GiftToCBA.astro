---
import { actions, isInputError, isActionError } from "astro:actions";
import "../styles/international-telephone-input.css";

const result = Astro.getActionResult(actions.gift.giftToCBA);
const inputErrors = isInputError(result?.error) ? result?.error.fields : {};
// const actionError = isActionError(result?.error);
---

<div id="container">
    <form method="POST" action={actions.gift.giftToCBA}>
        <h1>Send Book to CBA project</h1>
        <fieldset>
            <legend>Choose Theme and Budget</legend>
            <label for="theme"
                >Choose a theme for the <em>Children's Book</em></label
            >
            <p class="helper-label">
                Tell us the themes on which you would like us to add more children's books.
            </p>
            <textarea rows="6" transition:persist name="theme" id="theme"
            ></textarea>
            {
                inputErrors.theme && (
                    <span id="error">
                        Please check the text you have entered
                    </span>
                )
            }
            <label for="budget">Choose your budget for the book</label>
            <input
                transition:persist
                required
                type="range"
                name="budget"
                id="budget"
                min="500"
                max="2000"
                value="500"
                step="50"
            />
            <p id="budget-text">₹ <span id="budget-value"></span></p>
            {
                inputErrors.budget && (
                    <span id="error">Please check your budget again</span>
                )
            }
        </fieldset>

        <fieldset>
            <legend>Your Details</legend>
            <label for="name">Your Name</label>
            <input
                transition:persist
                required
                type="text"
                name="name"
                id="name"
            />
            {
                inputErrors.name && (
                    <span style="margin-top: -1rem" class="error">
                        Please check your name again
                    </span>
                )
            }
            <label for="email">Your Email</label>
            <input
                transition:persist
                required
                type="email"
                name="email"
                id="email"
            />
            {
                inputErrors.email && (
                    <span style="margin-top: -1rem" class="error">
                        Please check your email again
                    </span>
                )
            }
            <label for="phone">Your Phone</label>
            <div transition:persist class="iti">
                <input
                    transition:persist
                    required
                    type="tel"
                    name="phone"
                    id="phone"
                />
            </div>
            {
                inputErrors.phone && (
                    <span id="error">Please check your phone number again</span>
                )
            }
        </fieldset>

        <label for="message">Any suggestions, message or feedback for us</label>
        <textarea rows="5" transition:persist name="message" id="message"
        ></textarea>
        {
            inputErrors.message && (
                <span id="error">Please check the text you have entered</span>
            )
        }
        <input type="submit" id="submit" value="Gift the book" />
    </form>
</div>
<script src="../scripts/international-telephone-input.js"></script>
<script>
    // Update budget value
    const slider = document.querySelector("#budget") as HTMLInputElement;
    const value = document.querySelector("#budget-value");
    if(value){
        value.textContent = slider.value;
    }
    
    slider?.addEventListener('input', ()=>{
        if(value)
            value.textContent = slider.value;
    })
</script>
<style>
    #container {
        margin: 0 0.5rem;
        margin-bottom: 1rem;
    }
    form {
        display: flex;
        flex-direction: column;
        margin: auto;
        padding: 0.25rem;
        /* padding: 0rem 1.5rem 1.5rem 2rem; */
        gap: 0.5rem;
        max-width: 600px;
        background-color: transparent;
        border: none

    }
    h1 {
        text-align: center;
        margin-bottom: 1rem;
    }
    fieldset {
        /* margin: 1.2rem 0rem; */
        /* margin: 0; */
        padding: 1rem 1.2rem;
        border-color: oklch(95.57% 0.003 286.35);
        border-radius: 0.85rem;
        background-color: white;
        margin-bottom: 1rem;
    }
    input {
        width: 80%;
        margin-bottom: 1.5rem;
    }
    textarea {
        margin-bottom: 1.5rem;
        font-size: 1rem;
    }
    input[type="range"] {
        max-width: 240px;
    }
    legend {
        font-weight: 600;
        /* margin-left: 50%; */
    }
    #budget-text {
        margin-top: -1rem;
    }
    #message{
        margin-top: -0.5rem;
    }
    .alert {
        color: red;
        display: none;
        margin-top: -1rem;
        /* margin: 0; */
    }
    .helper-label {
        margin-top: -0.5rem;
        margin-bottom: 0.25rem;
        font-size: 0.9rem;
        color: oklch(35.02% 0.005 236.66);
    }
    #error {
        color: red;
        display: block;
        text-align: left;
    }
    .iti {
        position: relative;
        display: inline-block;
        /* margin-bottom: 1.5rem; */
    }
    
    label[for="address"]{
        margin-top: 1.5rem;
    }

    #phone {
        margin-top: 0;
        margin-bottom: 0;
        padding-left: 52px;
        padding-right: 6px;
    }
    #contribution-label {
        margin-top: 1rem;
    }
    label {
        font-weight: 500;
        margin-bottom: 0.4rem;
    }
    #submit {
        align-self: center;
        margin-bottom: 0rem;
    }
</style>
