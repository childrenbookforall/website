---
import { actions, isInputError, isActionError } from "astro:actions";
import "../styles/international-telephone-input.css";

const { groupId, goLive, cost, startDate } = Astro.props;
const today = new Date();


const result = Astro.getActionResult(actions.support.addConfirmation);
const inputErrors = isInputError(result?.error) ? result?.error.fields : {};
// const actionError = isActionError(result?.error);
---

<form method="POST" action={actions.support.addConfirmation}>
    <fieldset>
        <h1>Confirm Your Participation</h1>
        <p class="alert">This support group is closed</p>
        <label for="name">Name</label>
        <input transition:persist required type="text" name="name" id="name" />
        {
            inputErrors.name && (
                <span style="margin-top: -1rem" id="error">
                    Please check your name again
                </span>
            )
        }
        <label for="email">Email</label>
        <input
            transition:persist
            required
            type="email"
            name="email"
            id="email"
        />
        {
            inputErrors.email && (
                <span style="margin-top: -1rem" id="error">
                    Please check your email again
                </span>
            )
        }
        <!-- {
        actionError && (
            <span style="margin-top: -1rem" id="error">
                You are already registered for this reading
            </span>
        )
    } -->
        <label for="phone">Phone</label>
        <div transition:persist class="iti">
            <input
                transition:persist
                required
                type="tel"
                name="phone"
                id="phone"
            />
        </div>
        {
            inputErrors.phone && (
                <span id="error">Please check your phone number again</span>
            )
        }
        <input type="hidden" name="groupId" value={groupId} />
        <input type="hidden" name="cost" value={cost} />
        <input type="hidden" name="startDate" value={startDate} />
        <input type="submit" id="submit" value="Join the support group" />
    </fieldset>
</form>
<script src="../scripts/international-telephone-input.js"></script>
<script define:vars={{ startDate, goLive }}>
    const form = document.querySelector("form");
    const submitBtn = document.querySelector("#submit");
    form?.addEventListener("submit", () => {
        submitBtn?.setAttribute("disabled", "");
    });

    // logic for disabling the form if the date is passed
    const fieldset = document.querySelector("fieldset");
    const today = new Date();
    const reading_date = new Date(startDate);
    if(today > reading_date.setDate(reading_date.getDate()+ 1) || !goLive){
        document.querySelector('.alert').style.display = 'block';
        fieldset.setAttribute("disabled","");
    }
</script>
<style>
    form {
        display: flex;
        flex-direction: column;
        margin: auto;
        padding: 0rem 1.5rem 1.5rem 2rem;
        gap: 0.5rem;
        max-width: 400px;
    }
    fieldset{
        display: contents;
    }
    
    .alert{
        color: red;
        display: none;
        margin-top: -1rem;
        /* margin: 0; */
    }
    #error {
        color: red;
        display: block;
        text-align: left;
    }
    .iti {
        position: relative;
        display: inline-block;
    }
    #phone {
        margin-top: 0;
        margin-bottom: 0;
        padding-left: 52px;
        padding-right: 6px;
    }
    #contribution-label {
        margin-top: 1rem;
    }
    label {
        font-weight: 500;
    }
    .input-symbol-rupee {
        position: relative;
    }
    .input-symbol-rupee input {
        padding-left: 18px;
    }
    .input-symbol-rupee:before {
        position: absolute;
        top: 5px;
        content: "₹";
        left: 5px;
    }
    form{
        margin-top: 0;
    }
</style>
