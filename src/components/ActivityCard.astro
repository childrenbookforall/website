---
import { Icon } from "astro-icon/components";
import DateCard from "./DateCard.astro";
const { activity, url } = Astro.props;
const months = [
    "Jan",
    "Feb",
    "Mar",
    "Apr",
    "May",
    "Jun",
    "Jul",
    "Aug",
    "Sep",
    "Oct",
    "Nov",
    "Dec",
];
const displayFormattedDate = function (activityDate: Date) {
    const days = [
        "Sunday",
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
    ];
    const date = activityDate.getDate().toString();
    const month = months[activityDate.getMonth()];
    const year = activityDate.getFullYear().toString();
    const day = days[activityDate.getDay()];
    
    const formattedDate = `${date} ${month} ${year}`
    return formattedDate;
};
---

<a href={url}>
    <aside class="activity-card">
        <div class="activity">
            <img src={activity.image.url} alt={activity.image.alt} />
            <div class="activity-details">
                <h3>{activity.title}</h3>
                <p>{activity.description}</p>
            </div>
        </div>
        <div class="footer">
            <div class="owner">
                <img src={activity.owner.image} alt="profile photo">
                <p>{activity.owner.name}</p>
            </div>
            <span>Last Update: {displayFormattedDate(activity.lastUpdatedDate)}</span>
        </div>
    </aside>
</a>

<style>
    * {
        /* border: 1px solid red; */
    }
    .activity-card {
        display: flex;
        flex-direction: column;
        width: 80%;
        margin: auto;
        padding-bottom: 0.25rem;
        padding-top: 0.25rem;
        max-width: 800px;
    }
    .activity{
        display: flex;
        flex-direction: row;
        gap: 1rem;
    }
    .activity-details h3 {
        margin-bottom: 0;
    }
    .activity-details p {
        margin-top: 0.5rem;
    }

    a {
        color: black;
        font-style: normal;
        font-weight: normal;
        text-decoration: none;
    }
    a:hover {
        color: black;
        filter: none;
        text-decoration: none;
    }
    a:active {
        filter: none;
    }
    .activity img {
        height: auto;
        width: 85px;
        object-fit: contain;
        align-self: center;
        justify-content: center;
    }
    .footer{
        display: flex;
        flex-direction: row;
        justify-content: space-around;
        /* gap: 0.25rem; */
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 0;
        padding-bottom: 0;
        color: oklch(52.79% 0.005 271.32)
    }
    .owner{
        display: flex;
        flex-direction: row;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        color: oklch(35.02% 0.005 236.66);
    }
    .owner img{
        width: 25px;
        height: 25px;
        object-fit: contain;
        border: 1px solid gray;
        border-radius: 50%;
        padding: 2px;
    }
    
</style>
