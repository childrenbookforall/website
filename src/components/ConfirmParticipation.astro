---
import { actions, isInputError, isActionError } from "astro:actions";

const {readingDate} = Astro.props;

const result = Astro.getActionResult(actions.reading.addConfirmation);
const inputErrors = isInputError(result?.error)? result?.error.fields:{};
const actionError = isActionError(result?.error);
---
{actionError && <span id="error">You are already registered for this reading</span>}
<form method="POST" action={actions.reading.addConfirmation}>
    <h1>Confirm Your Participation</h1>
    <label for="name">Name</label>
    <input transition:persist required type="text" name="name" id="name" />
    {inputErrors.name && <span id="error">Please check your name again</span>}
    <label for="email">Email</label>
    <input transition:persist required type="email" name="email" id="email" />
    {inputErrors.email && <span id="error">Please check your email again</span>}
    <label for="phone">Phone</label>
    <input transition:persist required type="tel" name="phone" id="phone" />
    {inputErrors.phone && <span id="error">Please check your phone number again</span>}
    <label for="contribution">Amount you intend to contribute for the reading</label>
    <input transition:persist required type="number" name="contribution" id="contribution" />
    {inputErrors.contribution && <span id="error">Please check your contribution amount again</span>}
    <input type="hidden" name="readingDate" value={readingDate}>
    <input type="submit" id="submit" value="Send me an invite" />
</form>
<style>
    form {
        display: flex;
        flex-direction: column;
        max-width: 600px;
        margin: auto;
        padding: 0rem 1.5rem 1.5rem 2rem;
        gap: 0.5rem;
    }
    #error{
        color: red;
        display: block;
        text-align: center;
    }
</style>
