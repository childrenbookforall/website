---
import { actions, isInputError, isActionError } from "astro:actions";

const result = Astro.getActionResult(actions.gift.chooseOption);
const inputErrors = isInputError(result?.error) ? result?.error.fields : {};
const actionError = isActionError(result?.error);
---

{
    actionError && (
        <span id="error">Something went wrong. Please try again later.</span>
    )
}
<form method="POST" action={actions.gift.chooseOption}>
    <h1>Confirm Your Participation</h1>
    <label>
        <input
            transition:persist
            type="radio"
            name="receiver"
            value="self"
            required
        />
        <span>I want to give myself a gift</span>
    </label>
    <label>
        <input transition:persist type="radio" name="receiver" value="loved-one" />
        <span>I want to send the gift to a loved one</span>
    </label>
    <label>
        <input transition:persist type="radio" name="receiver" value="cba" />
        <span>I want to give a gift to Children's Book For All</span>
    </label>
    {
        inputErrors.receiver && (
            <span id="error">Please choose one of these options only</span>
        )
    }
    <input type="submit" value="Next" />

    <style>
        form {
            display: flex;
            flex-direction: column;
            max-width: 600px;
            margin: auto;
            padding: 0rem 1.5rem 1.5rem 2rem;
            gap: 0.5rem;
        }
        #error {
            color: red;
            display: block;
            text-align: center;
        }
    </style>
</form>
