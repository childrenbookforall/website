---
import Layout from "../../layouts/Layout.astro";

const calendar = Astro.cookies.get("_calendar")?.value;

if(!calendar){
    console.log(calendar);
    return Astro.redirect('/404');
}

const calendar_link = calendar.toString();

---

<Layout>
    <div class="container">
        <h2>Thank you 🌻</h2>
        <p>
            We hope to see you soon!<br>
            You can save the reading event to your calendar by clicking on the link below.
        </p>
        <a
            target="_blank"
            href={calendar_link}
        >
            Add to Calendar
        </a>
    </div>
</Layout>
<style>
    h2{
        text-align: center;
    }
    .container{
        width: 300px;
        margin: auto;
    }

    .container p{

    }
</style>
