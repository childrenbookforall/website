---
import Layout from "../../layouts/Layout.astro";
---

<Layout>
    <div class="container">
        <h2>You can contribute for the reading here</h2>
        <div class="payment-info">
            <span id="name">Arushi Ralli</span>
            <span id="phone">+91-9599944055</span>
            <img
                width="200"
                src="https://upload.wikimedia.org/wikipedia/commons/d/d0/QR_code_for_mobile_English_Wikipedia.svg"
                alt="UPI QR code"
            />
            <span id="upi-id">ralli.arushi12@okaxis</span>
        </div>
        <div class="confirmation-buttons">
            <button onclick="window.location.href='/readings/add-to-calendar'">I've contributed</button>
            <a href="/readings/add-to-calendar">I will contribute later</a>
        </div>
        
    </div>
</Layout>
<style>
    .container{
        max-width: 600px;
        margin: auto;
    }
    h2 {
        width: 90%;
        margin: auto;
        text-align: center;
        padding-bottom: 1rem;
        border-bottom: 1px solid lightgray;
        margin-bottom: 2rem;
    }

    span {
        display: block;
    }
    .payment-info {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 0.3rem;
    }
    #name {
        font-size: 1.8rem;
        font-weight: 600;
    }
    #phone {
        font-size: 1rem;
    }
    #upi-id {
        color: black;
    }
    button{
        display: block;
        margin: auto;
        margin-top: 1.5rem;
        font-size: 1rem;
        padding: 0.5rem 1.5rem
    }
    p{
        width: 80%;
        margin: auto;
        margin-top: 1.5rem;
        color: grey;
    }
    .confirmation-buttons{
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
    }
    a{
        color: grey
    }
</style>
