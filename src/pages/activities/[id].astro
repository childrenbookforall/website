---
import { getEntry, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const { id } = Astro.params;
if (id === undefined) {
  return Astro.redirect("/404");
}
const post = await getEntry("activities", id);

if (post === undefined) {
  return Astro.redirect("/404");
}
if (!post.rendered?.html) return Astro.rewrite("/activities/no-updates");

const { Content } = await render(post);

const months = [
  "Jan",
  "Feb",
  "Mar",
  "Apr",
  "May",
  "Jun",
  "Jul",
  "Aug",
  "Sep",
  "Oct",
  "Nov",
  "Dec",
];
const displayFormattedDate = function (activityDate: Date) {
  const days = [
    "Sunday",
    "Monday",
    "Tuesday",
    "Wednesday",
    "Thursday",
    "Friday",
    "Saturday",
  ];
  const date = activityDate.getDate().toString();
  const month = months[activityDate.getMonth()];
  const year = activityDate.getFullYear().toString();
  const day = days[activityDate.getDay()];

  const formattedDate = `${date} ${month} ${year}`;
  return formattedDate;
};
---

<Layout>
  <!-- <main> -->
  <section class="activity">
    <div class="content">
      <h1>{post.data.title}</h1>

      <!-- <p>{post.data.description}</p> -->
      <Content />
      <hr />
    </div>

    <a href="/activities">Back</a>
  </section>

  <!-- </main> -->
</Layout>

