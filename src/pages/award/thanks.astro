---
import Layout from "../../layouts/Layout.astro";
---

<Layout ogTitle="Thank you — CBA Award Fund" ogDescription="Thank you for registering your interest in the Children's Book for All Award Fund.">
    <section>
        <aside>
            <h1 style="text-align: center;">🌻</h1>
            <h2>Thank you for registering!</h2>
            <p>We will send the submission guidelines for the <strong>Children's Book for All Award Fund 2026</strong> to your email shortly.</p>
            <p>The application deadline is <strong>31 August 2026</strong>. We look forward to reading your story.</p>
            <p>For any questions, reach us at <a href="mailto:childrensbookforall@gmail.com">childrensbookforall@gmail.com</a></p>
        </aside>
    </section>
    <section>
        <a class="home" href="/" data-astro-reload>Back Home</a>
    </section>
</Layout>
<style>
    h2 {
        text-align: center;
    }
    aside p {
        text-align: center;
    }
    .home {
        margin-bottom: 3rem;
    }
</style>
