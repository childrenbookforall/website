---
import Layout from "../layouts/Layout.astro";
import SupportGroupCard from "../components/SupportGroupCard.astro";
import { db, SupportGroups, desc, eq } from "astro:db";

const supportGroups = await db
    .select()
    .from(SupportGroups)
    .where(eq(SupportGroups.goLive, true))
    .orderBy(desc(SupportGroups.date));

    const months = [
    "Jan",
    "Feb",
    "Mar",
    "Apr",
    "May",
    "Jun",
    "Jul",
    "Aug",
    "Sep",
    "Oct",
    "Nov",
    "Dec",
];

const displayFormattedDate = function (readingDate: Date) {
    const days = [
        "Sunday",
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
    ];
    const date = readingDate.getDate().toString();
    const month = months[readingDate.getMonth()];
    const year = readingDate.getFullYear().toString();
    const day = days[readingDate.getDay()];

    return { date: date, day: day, month: month, year: year };
};

const formatTime = function (time: number) {
    const hour_24 = Math.floor(time / 60);
    var minutes = time % 60;
    const prefix = hour_24 > 12 ? "pm" : "am";
    const hour_12 = hour_24 > 12 ? hour_24 - 12 : hour_24;
    const hour_in_string = hour_12.toString();
    const minutes_in_string =
        minutes < 10 ? "0" + minutes.toString() : minutes.toString();
    return hour_in_string.concat(":", minutes_in_string, " ", prefix);
};

const displayFormattedTimings = function (startTime: number, endTime: number) {
    return formatTime(startTime).concat(" - ", formatTime(endTime));
};
---

<Layout>
    <header>
        <h2>Support Groups</h2>
        <p>Experience safety, connection, validation and growth</p>
    </header>
    <section>
        {
            supportGroups.length === 0 ? (
                <em>No Upcoming Support Groups</em>
            ) : (
                <div>
                    {supportGroups
                        .slice(0)
                        .reverse()
                        .map((group) => {
                            return (
                               <SupportGroupCard
                                groupId={group.id}
                                coverImage={group.coverImage}
                                date={displayFormattedDate(group.date)}
                                time={displayFormattedTimings(
                                    group.startTime,
                                    group.endTime,
                                )}
                                location={group.location}
                                sessionsCount={group.sessionsCount}
                                frequency={group.frequency}
                                description={group.description}
                                cost={group.cost}
                                tags={group.tags?.split(",")}/>
                            );
                        })}
                </div>
            )
        }
    </section>
</Layout>

<style>
    header {
        margin-top: 1rem;
        padding-top: 0rem;
    }

    header h2 {
        font-size: 2rem;
        margin: 0rem;
        padding: 0rem;
    }
    header p {
        margin-top: 0rem;
        font-size: 1.2rem;
    }
    section {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        width: 100%;
        margin: auto;
        /* flex-wrap: nowrap; */
    }
    section div {
        display: flex;
        flex-direction: row;
        align-items: center;
        flex-wrap: wrap;
        width: 100%;
        justify-content: center;
    }
</style>