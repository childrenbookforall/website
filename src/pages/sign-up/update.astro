---
import UpdateMemberForm from "../../components/UpdateMemberForm.astro";
import Layout from "../../layouts/Layout.astro";

import { actions } from "astro:actions"
const result = Astro.getActionResult(actions.member.updateMember);
if (result && !result.error) {
  return Astro.redirect('/sign-up/thanks');
}
const actionError = result?.error?.status === 500;
if (actionError){
  return Astro.redirect('/500');
}
---

<Layout>
    <UpdateMemberForm/>
</Layout>