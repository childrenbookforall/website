---
import Layout from "../../layouts/Layout.astro";
import GiftToLovedOne from "../../components/GiftToLovedOne.astro";

import { actions } from "astro:actions"

const result = Astro.getActionResult(actions.gift.toLovedOne);
if (result && !result.error) {
  console.log(result);
  return Astro.redirect('/gift/thanks');
}
else{
    console.log(result?.error)
}
---

<Layout>
    <GiftToLovedOne/>
</Layout>