---
import Layout from "../../layouts/Layout.astro";
import { actions } from "astro:actions";
import GiftToCBA from "../../components/GiftToCBA.astro";

const result = Astro.getActionResult(actions.gift.giftToCBA);

if (result && !result.error) {
  return Astro.redirect("/gift/payment");
} 

const actionError = result?.error?.status === 500;
if (actionError){
  return Astro.redirect('/500');
}
---

<Layout>
    <GiftToCBA/>
</Layout>