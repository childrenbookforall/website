---
import Layout from "../../layouts/Layout.astro";
import GiftToSelf from "../../components/GiftToSelf.astro";
import { actions } from "astro:actions";

const result = Astro.getActionResult(actions.gift.giftToSelf);

if (result && !result.error) {
  return Astro.redirect("/gift/payment");
} 

const actionError = result?.error?.status === 500;
if (actionError){
  return Astro.redirect('/500');
}
---

<Layout>
    <GiftToSelf/>
</Layout>