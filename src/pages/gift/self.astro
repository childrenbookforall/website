---
import Layout from "../../layouts/Layout.astro";
import GiftToSelf from "../../components/GiftToSelf.astro";

import { actions } from "astro:actions"

const result = Astro.getActionResult(actions.gift.toSelf);
if (result && !result.error) {
  return Astro.redirect('/gift/thanks');
}
else{
    console.log(result?.error)
}
---

<Layout>
    <GiftToSelf/>
</Layout>