---
import Layout from "../layouts/Layout.astro";
import AwardSignUp from "../components/AwardSignUp.astro";
import { actions } from "astro:actions";

const result = Astro.getActionResult(actions.award.registerForAward);

if (result && !result.error) {
    return Astro.redirect("/award/thanks");
}
---

<Layout
    ogTitle="CBA Award Fund 2026 — Children's Book for All"
    ogDescription="An award championing aspiring writers and illustrators telling stories about underrepresented communities. Max prize INR 50,000."
    hideNotificationBar={true}
>
    <main>
        <div class="info">
            <img src="https://ik.imagekit.io/ty6gikkxo/cbaAward.png" alt="Children's Book for All Award Fund" />
            <h1>Children's Book for All Award Fund 2026</h1>
            <p class="tagline"><em>for stories that deserve to be told</em></p>

            <div class="content">
                <p>
                    <em>Children's Book for All</em> is initiating an award fund to support and champion aspiring writers looking to create
                    picture books about <strong>underrepresented communities</strong> and
                    <strong>underrepresented themes</strong> — stories that often get overlooked in mainstream publishing.
                </p>

                <h3>Who can apply</h3>
                <ul>
                    <li>Indian citizens, aged 18 and above</li>
                    <li>Unpublished writers with original and unpublished work not under consideration elsewhere</li>
                </ul>

                <h3>What we're looking for</h3>
                <ul>
                    <li>Stories featuring lives of people from marginalized communities - Dalit, Bahujan, Adivasis, people with disabilities, LGBTQIA+ youth, economically disadvantaged, religious and linguistic minorities</li>
                    <li>Themes rarely explored in mainstream Indian children's publishing: mental health, expression of gender identities, displacement and migration, family complexities, environmental anxiety, etc.`</li>
                    <li>Regions and landscapes underrepresented in children's literature</li>
                    <li>Authentic, thoughtful storytelling - emerging from lived experiences</li>
                </ul>
                <div class="badges">
                    <span class="badge blue">Max Prize Amount: ₹ 50,000</span>
                    <p><em>Last Date to Apply: 31 August 2026</em></p>
                </div>
            </div>
        </div>

        <div class="register">
            <AwardSignUp />
        </div>
    </main>
</Layout>

<style>
    main {
        display: flex;
        flex-wrap: wrap;
        flex-direction: row;
        justify-content: center;
        align-items: flex-start;
        gap: 3rem;
        padding-bottom: 4rem;
    }

    .info {
        display: flex;
        flex-direction: column;
        max-width: 560px;
    }

    .info img {
        max-width: 420px;
        width: 100%;
        margin: auto;
        padding: 0;
    }

    h1 {
        text-align: center;
        margin-bottom: 0.25rem;
        text-wrap: balance;
    }

    .tagline {
        text-align: center;
        font-size: 1.1rem;
        margin-top: 0;
        margin-bottom: 1.5rem;
        color: #555;
    }

    .content {
        max-width: 560px;
        margin: auto;
    }

    .content p {
        font-size: 1.05rem;
        line-height: 1.6;
    }

    .content h3 {
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .content ul {
        margin: 0;
        padding-left: 1.25rem;
    }

    .content ul li {
        margin-bottom: 0.4rem;
        line-height: 1.5;
    }

    .badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 1.25rem 0;
    }

    .badge {
        border-radius: 15px;
        padding: 0.3rem 0.9rem;
        font-weight: 600;
        font-style: normal;
        font-size: 0.875rem;
        color: white;
        display: inline-block;
    }

    .badge.blue {
        background-color: #344cb7;
    }

    .badge.teal {
        background-color: var(--color-secondary);
    }

    .prizes {
        margin-top: 1.5rem;
    }

    .prize-note {
        font-size: 0.9rem;
        color: #555;
        margin-top: 0;
        margin-bottom: 0.75rem;
    }

    .prize-tiers {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .tier {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.95rem;
    }

    .register {
        padding-top: 0.5rem;
        position: sticky;
        top: 2rem;
    }

    @media (max-width: 768px) {
        .register {
            position: static;
            width: 100%;
            display: flex;
            justify-content: center;
        }
    }
</style>
